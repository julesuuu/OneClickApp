{
  "builds": [
    {
      "src": "frontend/src",
      "use": "@vercel/static",
      "config": {
        "outputDir": "dist"
      }
    },
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "index.js" },
    { "handle": "/?" },
    { "src": "/(.*)", "dest": "/frontend/src/dist/$1" }
  ]
}
